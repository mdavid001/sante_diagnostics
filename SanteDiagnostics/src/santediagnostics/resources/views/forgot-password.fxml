<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="620.0" prefWidth="860.0" styleClass="root"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="santediagnostics.resources.controllers.ForgotPasswordController">
    <center>
        <StackPane>
            <GridPane styleClass="form-surface">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="46.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="54.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" />
                </rowConstraints>

                <!-- LEFT: brand panel -->
                <VBox alignment="CENTER" styleClass="brand-panel" GridPane.columnIndex="0">
                    <Label styleClass="brand-logo" text="⚕" />
                    <Label styleClass="brand-name" text="Sante Diagnostics" />
                    <Label maxWidth="240.0" styleClass="brand-sub"
                           text="Laboratory Information Management System" />
                    <Region prefHeight="26.0" />
                    <Label styleClass="brand-pill"
                           text="Administrative Governance • Precision • Transparency" />
                </VBox>

                <!-- RIGHT: forgot-password form -->
                <VBox styleClass="form-container" GridPane.columnIndex="1">
                    <padding><Insets top="32.0" /></padding>

                    <Label styleClass="auth-title" text="Reset your password" />
                    <Label styleClass="auth-subtitle"
                           text="Enter your account email and we'll send you a 6-character code." />

                    <Label styleClass="field-label" text="Email">
                        <VBox.margin><Insets bottom="6.0" top="22.0" /></VBox.margin>
                    </Label>
                    <TextField fx:id="emailField"
                               promptText="you@example.com"
                               styleClass="form-field" />

                    <Button fx:id="sendCodeBtn" maxWidth="Infinity"
                            mnemonicParsing="false" onAction="#handleSendCode"
                            styleClass="primary-btn" text="Send reset code">
                        <VBox.margin><Insets top="16.0" /></VBox.margin>
                    </Button>

                    <!-- Phase 2 — hidden until a code is sent -->
                    <VBox fx:id="resetBox" spacing="0">
                        <Label styleClass="field-label" text="Reset code">
                            <VBox.margin><Insets bottom="6.0" top="22.0" /></VBox.margin>
                        </Label>
                        <TextField fx:id="codeField"
                                   promptText="6-character code"
                                   styleClass="form-field" />

                        <Label styleClass="field-label" text="New password">
                            <VBox.margin><Insets bottom="6.0" top="14.0" /></VBox.margin>
                        </Label>
                        <PasswordField fx:id="newPasswordField"
                                       promptText="At least 6 characters"
                                       styleClass="form-field" />

                        <Label styleClass="field-label" text="Confirm new password">
                            <VBox.margin><Insets bottom="6.0" top="14.0" /></VBox.margin>
                        </Label>
                        <PasswordField fx:id="confirmPasswordField"
                                       promptText="Repeat password"
                                       styleClass="form-field" />

                        <Button fx:id="resetBtn" maxWidth="Infinity"
                                mnemonicParsing="false" onAction="#handleReset"
                                styleClass="primary-btn" text="Reset password">
                            <VBox.margin><Insets top="16.0" /></VBox.margin>
                        </Button>
                    </VBox>

                    <Label fx:id="statusLabel" styleClass="error-text" text=" ">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                    </Label>

                    <HBox alignment="CENTER" spacing="6.0">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                        <Label onMouseClicked="#handleBackToLogin"
                               styleClass="link-label" text="Back to login" />
                    </HBox>
                </VBox>
            </GridPane>

            <!-- Overlay -->
            <StackPane fx:id="overlayPane" style="-fx-background-color: rgba(255,255,255,0.6);">
                <ProgressIndicator maxHeight="48.0" maxWidth="48.0" />
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
