<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" styleClass="dashboard-scroll"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="santediagnostics.resources.controllers.ResultUploadController">

    <VBox spacing="20.0" styleClass="dashboard-container">
        <padding><Insets top="4.0" right="4.0" bottom="20.0" left="4.0" /></padding>

        <!-- Header with Back Button and Title -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button onAction="#handleBackToDashboard" styleClass="back-icon-button">
                <graphic>
                    <FontAwesomeIconView glyphName="ARROW_LEFT" size="16" fill="#0E3A3F" />
                </graphic>
            </Button>
            <VBox>
                <Label text="Result Upload &amp; Verification" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0E3A3F;" />
                <Label text="Enter test results and verify before releasing to customers" style="-fx-font-size: 12px; -fx-text-fill: #6B8A90;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
        </HBox>

        <!-- Search bar -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <TextField fx:id="searchField"
                       promptText="Search by customer or test…"
                       styleClass="form-field"
                       HBox.hgrow="ALWAYS"
                       maxWidth="Infinity"
                       onKeyReleased="#handleSearch" />
        </HBox>

        <!-- Filter chips + count -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <HBox spacing="8.0">
                <fx:define>
                    <ToggleGroup fx:id="filterGroup" />
                </fx:define>
                <ToggleButton fx:id="filterAll" text="All" selected="true"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterAll" />
                <ToggleButton fx:id="filterAwaiting" text="Awaiting result"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterAwaiting" />
                <ToggleButton fx:id="filterPending" text="Pending verification"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterPending" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="countLabel" styleClass="muted-label" text="" />
            <Button fx:id="refreshBtn" text="Refresh" onAction="#handleRefresh"
                    styleClass="ghost-btn" />
        </HBox>

        <!-- Results table -->
        <StackPane>
            <TableView fx:id="resultTable" styleClass="data-table" prefHeight="470.0" minWidth="1060.0">
                <columns>
                    <TableColumn fx:id="colRequestId" prefWidth="70.0" text="Req #" />
                    <TableColumn fx:id="colCustomer" prefWidth="160.0" text="Customer" />
                    <TableColumn fx:id="colTest" prefWidth="175.0" text="Test" />
                    <TableColumn fx:id="colFormat" prefWidth="90.0" text="Format" />
                    <TableColumn fx:id="colFile" prefWidth="180.0" text="Attachment" />
                    <TableColumn fx:id="colStage" prefWidth="140.0" text="Stage" />
                    <TableColumn fx:id="colAction" prefWidth="220.0" text="Action" />
                </columns>
                <placeholder>
                    <Label styleClass="muted-label" text="No results in this view." />
                </placeholder>
            </TableView>

            <!-- loading overlay -->
            <StackPane fx:id="overlayPane" style="-fx-background-color: rgba(244,248,248,0.6);"
                       visible="false" managed="false">
                <Label styleClass="muted-label" text="Working..." />
            </StackPane>

            <!-- result-entry popup -->
            <StackPane fx:id="resultPopup" style="-fx-background-color: rgba(14,58,63,0.32);"
                       visible="false" managed="false">
                <VBox alignment="CENTER" maxWidth="450.0" maxHeight="500.0"
                      styleClass="confirm-card">
                    <Label fx:id="resultPopupTitle" styleClass="confirm-title" text="Enter Result">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                    </Label>
                    <Label fx:id="resultPopupSub" styleClass="confirm-message" wrapText="true"
                           text="">
                        <VBox.margin><Insets top="8.0" left="10.0" right="10.0" /></VBox.margin>
                    </Label>

                    <!-- Numeric input -->
                    <VBox fx:id="numericBox" spacing="8.0" visible="false" managed="false">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                        <Label text="Result value" styleClass="field-label" />
                        <TextField fx:id="numericField" promptText="Enter numeric result"
                                   styleClass="form-field" />
                    </VBox>

                    <!-- Text input -->
                    <VBox fx:id="textBox" spacing="8.0">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                        <Label fx:id="textBoxLabel" text="Result / interpretation" styleClass="field-label" />
                        <TextArea fx:id="textField" promptText="Enter result details"
                                  styleClass="form-field" prefRowCount="4" wrapText="true" />
                    </VBox>

                    <!-- File attachment -->
                    <VBox fx:id="fileBox" spacing="8.0">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                        <Label text="Attach file (optional)" styleClass="field-label" />
                        <HBox spacing="10.0">
                            <Button fx:id="chooseFileBtn" text="Choose File" onAction="#handleChooseFile"
                                    styleClass="ghost-btn" />
                            <Label fx:id="chosenFileLabel" text="No file chosen" styleClass="muted-label"
                                   wrapText="true" HBox.hgrow="ALWAYS" />
                        </HBox>
                    </VBox>

                    <Label fx:id="resultError" styleClass="error-text" wrapText="true"
                           visible="false" managed="false">
                        <VBox.margin><Insets top="10.0" /></VBox.margin>
                    </Label>

                    <HBox alignment="CENTER" spacing="12.0">
                        <VBox.margin><Insets top="20.0" /></VBox.margin>
                        <Button text="Cancel" onAction="#handleCancelResult"
                                styleClass="ghost-btn" prefWidth="140.0" />
                        <Button text="Save Result" onAction="#handleSaveResult"
                                styleClass="primary-btn" prefWidth="140.0" />
                    </HBox>
                </VBox>
            </StackPane>

            <!-- verify popup -->
            <StackPane fx:id="verifyPopup" style="-fx-background-color: rgba(14,58,63,0.32);"
                       visible="false" managed="false">
                <VBox alignment="CENTER" maxWidth="400.0" maxHeight="300.0"
                      styleClass="confirm-card">
                    <StackPane styleClass="confirm-icon-circle">
                        <Label styleClass="confirm-icon-mark" text="✓" />
                    </StackPane>
                    <Label styleClass="confirm-title" text="Verify Result">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                    </Label>
                    <Label fx:id="verifyMessage" styleClass="confirm-message" wrapText="true"
                           text="">
                        <VBox.margin><Insets top="8.0" left="10.0" right="10.0" /></VBox.margin>
                    </Label>
                    <HBox alignment="CENTER" spacing="12.0">
                        <VBox.margin><Insets top="20.0" /></VBox.margin>
                        <Button text="Cancel" onAction="#handleCancelVerify"
                                styleClass="ghost-btn" prefWidth="140.0" />
                        <Button text="Verify &amp; Release" onAction="#handleConfirmVerify"
                                styleClass="primary-btn" prefWidth="140.0" />
                    </HBox>
                </VBox>
            </StackPane>
        </StackPane>

    </VBox>
</ScrollPane>