<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="860.0" styleClass="root"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="santediagnostics.resources.controllers.VerifyEmailController">
    <center>
        <StackPane>
            <GridPane styleClass="form-surface">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="46.0" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="54.0" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints vgrow="ALWAYS" />
                </rowConstraints>

                <!-- LEFT: brand panel -->
                <VBox alignment="CENTER" styleClass="brand-panel" GridPane.columnIndex="0">
                    <Label styleClass="brand-logo" text="⚕" />
                    <Label styleClass="brand-name" text="Sante Diagnostics" />
                    <Label maxWidth="240.0" styleClass="brand-sub"
                           text="Laboratory Information Management System" />
                    <Region prefHeight="26.0" />
                    <Label styleClass="brand-pill"
                           text="Administrative Governance • Precision • Transparency" />
                </VBox>

                <!-- RIGHT: verify form -->
                <VBox styleClass="form-container" GridPane.columnIndex="1">
                    <padding><Insets top="40.0" /></padding>

                    <Label styleClass="auth-title" text="Verify your email" />
                    <Label styleClass="auth-subtitle"
                           text="Enter the 6-character code we sent to your inbox." />

                    <Label styleClass="field-label" text="Code sent to">
                        <VBox.margin><Insets bottom="4.0" top="22.0" /></VBox.margin>
                    </Label>
                    <Label fx:id="emailLabel" styleClass="muted-label" text="-" />

                    <Label styleClass="field-label" text="Verification code">
                        <VBox.margin><Insets bottom="6.0" top="22.0" /></VBox.margin>
                    </Label>
                    <TextField fx:id="codeField"
                               promptText="6-character code"
                               styleClass="form-field" />

                    <Label fx:id="statusLabel" styleClass="error-text" text=" ">
                        <VBox.margin><Insets top="10.0" /></VBox.margin>
                    </Label>

                    <Button fx:id="verifyBtn" maxWidth="Infinity"
                            mnemonicParsing="false" onAction="#handleVerify"
                            styleClass="primary-btn" text="Verify">
                        <VBox.margin><Insets top="12.0" /></VBox.margin>
                    </Button>

                    <HBox alignment="CENTER" spacing="6.0">
                        <VBox.margin><Insets top="18.0" /></VBox.margin>
                        <Label styleClass="muted-label" text="Didn't get a code?" />
                        <Label onMouseClicked="#handleResend"
                               styleClass="link-label" text="Resend code" />
                    </HBox>

                    <HBox alignment="CENTER" spacing="6.0">
                        <VBox.margin><Insets top="10.0" /></VBox.margin>
                        <Label onMouseClicked="#handleBackToLogin"
                               styleClass="link-label" text="Back to login" />
                    </HBox>
                </VBox>
            </GridPane>

            <!-- Overlay -->
            <StackPane fx:id="overlayPane" style="-fx-background-color: rgba(255,255,255,0.6);">
                <ProgressIndicator maxHeight="48.0" maxWidth="48.0" />
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
