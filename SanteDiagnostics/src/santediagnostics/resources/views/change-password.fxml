<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="560.0" prefWidth="860.0" styleClass="root"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="santediagnostics.resources.controllers.ChangePasswordController">
    <center>
        <StackPane>
            <HBox styleClass="form-surface">
                <!-- LEFT: brand panel -->
                <VBox alignment="CENTER" prefWidth="395.0" styleClass="brand-panel">
                    <Label styleClass="brand-logo" text="&#x1F512;" />
                    <Label styleClass="brand-name" text="Secure your account" />
                    <Label maxWidth="250.0" styleClass="brand-sub"
                           text="Your account was created by laboratory staff. Set a private password to continue." />
                    <Region prefHeight="26.0" />
                    <Label styleClass="brand-pill" text="Required on first login" />
                </VBox>

                <!-- RIGHT: change-password form -->
                <VBox styleClass="form-container" HBox.hgrow="ALWAYS" alignment="CENTER_LEFT">
                    <padding><Insets top="40.0" left="44.0" right="44.0" /></padding>

                    <Label styleClass="auth-title" text="Change your password" />
                    <Label fx:id="subtitleLabel" maxWidth="360.0" styleClass="auth-subtitle"
                           text="For your security, please set a new password before continuing." />

                    <Label styleClass="field-label" text="New password">
                        <VBox.margin><Insets top="26.0" bottom="6.0" /></VBox.margin>
                    </Label>
                    <StackPane>
                        <TextField fx:id="newVisibleField" styleClass="form-field"
                                   visible="false" managed="false" />
                        <PasswordField fx:id="newPasswordField" styleClass="form-field"
                                       promptText="At least 6 characters" />
                        <FontAwesomeIconView fx:id="newEyeIcon" fill="#16B0A6" glyphName="EYE"
                                             size="14" onMouseClicked="#handleShowNew"
                                             StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin><Insets right="12.0" /></StackPane.margin>
                        </FontAwesomeIconView>
                    </StackPane>

                    <Label styleClass="field-label" text="Confirm new password">
                        <VBox.margin><Insets top="16.0" bottom="6.0" /></VBox.margin>
                    </Label>
                    <StackPane>
                        <TextField fx:id="confirmVisibleField" styleClass="form-field"
                                   visible="false" managed="false" />
                        <PasswordField fx:id="confirmPasswordField" styleClass="form-field"
                                       promptText="Repeat new password" />
                        <FontAwesomeIconView fx:id="confirmEyeIcon" fill="#16B0A6" glyphName="EYE"
                                             size="14" onMouseClicked="#handleShowConfirm"
                                             StackPane.alignment="CENTER_RIGHT">
                            <StackPane.margin><Insets right="12.0" /></StackPane.margin>
                        </FontAwesomeIconView>
                    </StackPane>

                    <Label fx:id="errorLabel" styleClass="error-text">
                        <VBox.margin><Insets top="8.0" /></VBox.margin>
                    </Label>

                    <Button fx:id="saveBtn" maxWidth="Infinity" mnemonicParsing="false"
                            onAction="#handleSave" styleClass="primary-btn"
                            text="Save and continue">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                    </Button>
                </VBox>
            </HBox>

            <!-- loading overlay -->
            <StackPane fx:id="overlayPane" style="-fx-background-color: rgba(14,58,63,0.32);"
                       visible="false">
                <ProgressIndicator prefHeight="56.0" prefWidth="56.0" />
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
