<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    sample-tracking.fxml  (Lab Attendant)
    Tracks each paid request's sample through the lifecycle:
    awaiting collection -> collected -> processing -> processed.
    Each row shows the right action button for its current stage.
-->
<ScrollPane fitToWidth="true" hbarPolicy="AS_NEEDED" styleClass="dashboard-scroll"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="santediagnostics.resources.controllers.SampleTrackingController">

    <VBox spacing="20.0" styleClass="dashboard-container">
        <padding><Insets top="4.0" right="4.0" bottom="20.0" left="4.0" /></padding>

        <!-- Search bar -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <TextField fx:id="searchField"
                       promptText="Search by customer or test…"
                       styleClass="form-field"
                       HBox.hgrow="ALWAYS"
                       maxWidth="Infinity"
                       onKeyReleased="#handleSearch" />
        </HBox>

        <!-- Filter chips + count -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <HBox spacing="8.0">
                <fx:define>
                    <ToggleGroup fx:id="filterGroup" />
                </fx:define>
                <ToggleButton fx:id="filterAll" text="All" selected="true"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterAll" />
                <ToggleButton fx:id="filterAwaiting" text="Awaiting collection"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterAwaiting" />
                <ToggleButton fx:id="filterCollected" text="Collected"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterCollected" />
                <ToggleButton fx:id="filterProcessing" text="Processing"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterProcessing" />
                <ToggleButton fx:id="filterProcessed" text="Processed"
                              toggleGroup="$filterGroup" styleClass="filter-chip"
                              onAction="#handleFilterProcessed" />
            </HBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="countLabel" styleClass="muted-label" text="" />
            <Button fx:id="refreshBtn" text="Refresh" onAction="#handleRefresh"
                    styleClass="ghost-btn" />
        </HBox>

        <!-- Samples table -->
        <StackPane>
            <TableView fx:id="sampleTable" styleClass="data-table" prefHeight="470.0" minWidth="980.0">
                <columns>
                    <TableColumn fx:id="colRequestId" prefWidth="70.0" text="Req #" />
                    <TableColumn fx:id="colCustomer" prefWidth="160.0" text="Customer" />
                    <TableColumn fx:id="colTest" prefWidth="175.0" text="Test" />
                    <TableColumn fx:id="colStage" prefWidth="150.0" text="Stage" />
                    <TableColumn fx:id="colUpdated" prefWidth="140.0" text="Last update" />
                    <TableColumn fx:id="colAction" prefWidth="230.0" text="Action" />
                </columns>
                <placeholder>
                    <Label styleClass="muted-label" text="No samples in this view." />
                </placeholder>
            </TableView>

            <!-- loading overlay -->
            <StackPane fx:id="overlayPane" style="-fx-background-color: rgba(244,248,248,0.6);"
                       visible="false" managed="false">
                <Label styleClass="muted-label" text="Working..." />
            </StackPane>

            <!-- collect-sample popup -->
            <StackPane fx:id="collectPopup" style="-fx-background-color: rgba(14,58,63,0.32);"
                       visible="false" managed="false">
                <VBox alignment="CENTER" maxWidth="400.0" maxHeight="300.0"
                      styleClass="confirm-card">
                    <StackPane styleClass="confirm-icon-circle">
                        <Label styleClass="confirm-icon-mark" text="&#9883;" />
                    </StackPane>
                    <Label styleClass="confirm-title" text="Collect Sample">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                    </Label>
                    <Label fx:id="collectMessage" styleClass="confirm-message" wrapText="true"
                           text="">
                        <VBox.margin><Insets top="8.0" left="10.0" right="10.0" /></VBox.margin>
                    </Label>
                    <TextArea fx:id="collectNotes" promptText="Optional notes (e.g. sample type, condition)"
                              styleClass="form-field" prefRowCount="3" wrapText="true" maxWidth="320.0">
                        <VBox.margin><Insets top="14.0" /></VBox.margin>
                    </TextArea>
                    <HBox alignment="CENTER" spacing="12.0">
                        <VBox.margin><Insets top="20.0" /></VBox.margin>
                        <Button text="Cancel" onAction="#handleCancelCollect"
                                styleClass="ghost-btn" prefWidth="140.0" />
                        <Button text="Collect sample" onAction="#handleConfirmCollect"
                                styleClass="primary-btn" prefWidth="140.0" />
                    </HBox>
                </VBox>
            </StackPane>
        </StackPane>

    </VBox>
</ScrollPane>
