<?xml version="1.0" encoding="UTF-8"?>

<?import de.jensd.fx.glyphs.fontawesome.FontAwesomeIconView?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    result-vault.fxml
    Customer's results page. Shows completed test results
    with status and a View/Download button per result.
-->
<StackPane stylesheets="@../css/styles.css"
           xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="santediagnostics.resources.controllers.ResultVaultController">

    <!-- ==================== MAIN CONTENT ==================== -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="dashboard-scroll">
        <VBox spacing="20.0" styleClass="dashboard-container">
            <padding><Insets top="4.0" right="4.0" bottom="20.0" left="4.0" /></padding>

            <!-- Header + Search -->
            <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E4EDED; -fx-border-radius: 12; -fx-border-width: 1; -fx-padding: 20 24 20 24;">
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <FontAwesomeIconView fill="#16B0A6" glyphName="FOLDER_OPEN" size="22" />
                    <VBox spacing="2.0">
                        <Label text="My Results" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #11242A;" />
                        <Label text="View and download your test results" styleClass="muted-label" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="resultCountLabel" text="0 results" styleClass="muted-label" />
                </HBox>
                <TextField fx:id="searchField" promptText="Search results by test name..."
                           styleClass="form-field" />
            </VBox>

            <!-- Result Cards (built by controller) -->
            <VBox fx:id="resultCardsPane" spacing="12.0" />

        </VBox>
    </ScrollPane>

    <!-- ==================== RESULT VIEWER POPUP ==================== -->
    <StackPane fx:id="viewerPopup" visible="false" managed="false"
               style="-fx-background-color: rgba(17,36,42,0.55);">
        <VBox alignment="CENTER" maxWidth="720.0" maxHeight="640.0" spacing="14.0"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 24 28 24 28; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 20, 0, 0, 6);">

            <!-- Close button -->
            <HBox alignment="CENTER_RIGHT">
                <Button text="✕" onAction="#handleCloseViewer"
                        style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-text-fill: #6B7E84; -fx-cursor: hand;" />
            </HBox>

            <!-- Result info -->
            <VBox alignment="CENTER" spacing="6.0">
                <FontAwesomeIconView fx:id="viewerIcon" fill="#16B0A6" glyphName="FILE_TEXT" size="30" />
                <Label fx:id="viewerTestName" text="Test Name"
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #11242A;" />
                <Label fx:id="viewerDate" text="Completed: --"
                       style="-fx-font-size: 13px; -fx-text-fill: #6B7E84;" />
            </VBox>

            <!-- Result value (text / numeric) -->
            <VBox fx:id="viewerValueBox" spacing="8.0"
                  style="-fx-background-color: #F4F8F8; -fx-background-radius: 10; -fx-padding: 16 22 16 22;">
                <Label text="Result" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7E84;" />
                <Label fx:id="viewerValueLabel" text="--"
                       style="-fx-font-size: 15px; -fx-text-fill: #11242A; -fx-wrap-text: true;" />
            </VBox>

            <!-- Inline IMAGE preview -->
            <StackPane fx:id="imagePreviewBox" visible="false" managed="false"
                       style="-fx-background-color: #F4F8F8; -fx-background-radius: 10; -fx-padding: 10;">
                <ImageView fx:id="resultImageView" preserveRatio="true"
                           fitWidth="640" fitHeight="420" />
            </StackPane>

            <!-- PDF stub: tells the customer to click "Open PDF" -->
            <VBox fx:id="pdfPreviewBox" visible="false" managed="false" alignment="CENTER" spacing="6.0"
                  style="-fx-background-color: #F4F8F8; -fx-background-radius: 10; -fx-padding: 24;">
                <FontAwesomeIconView fill="#16B0A6" glyphName="FILE_PDF_ALT" size="42" />
                <Label text="PDF report ready" style="-fx-font-weight: bold; -fx-text-fill: #11242A;" />
                <Label text="Click 'Open PDF' to view it in your system's PDF reader."
                       style="-fx-font-size: 12px; -fx-text-fill: #6B7E84;" wrapText="true" />
            </VBox>

            <!-- Action row: primary View/Open, secondary Download -->
            <HBox fx:id="viewerActionRow" alignment="CENTER" spacing="10.0"
                  visible="false" managed="false">
                <Button fx:id="viewerOpenBtn" text="Open PDF" onAction="#handleOpenInSystem"
                        styleClass="primary-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <graphic><FontAwesomeIconView fill="WHITE" glyphName="EXTERNAL_LINK" size="14" /></graphic>
                    <padding><Insets top="10" right="14" bottom="10" left="14" /></padding>
                </Button>
                <Button fx:id="viewerDownloadBtn" text="Download" onAction="#handleDownload"
                        styleClass="ghost-btn" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                    <graphic><FontAwesomeIconView fill="#11242A" glyphName="DOWNLOAD" size="14" /></graphic>
                    <padding><Insets top="10" right="14" bottom="10" left="14" /></padding>
                </Button>
            </HBox>
        </VBox>
    </StackPane>

</StackPane>
